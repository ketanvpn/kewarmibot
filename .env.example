# KeWarMiBot — Environment Configuration
# Copy this file to .env and fill in your values

# Telegram Bot Token (from @BotFather)
BOT_TOKEN=your_bot_token_here

# Admin chat IDs (comma-separated)
ADMIN_CHAT_IDS=690744680

# Encryption key (32 bytes hex = 64 chars)
# Generate with: python3 -c "import os; print(os.urandom(32).hex())"
ENCRYPTION_KEY=generate_a_unique_64_char_hex_key

# Database URL (SQLite default, Postgres supported)
DATABASE_URL=sqlite+aiosqlite:///data/kewarmibot.db

# ─── Payment Gateway (KetantechPay) ────────────────────
# Get these from your KetantechPay dashboard
KETANTECHPAY_BASE_URL=https://ketantech.my.id/api/payment
KETANTECHPAY_CLIENT_KEY=your_client_key_here

# ─── Webhook Server ────────────────────────────────────
WEBHOOK_BASE_URL=https://your-domain.com
WEBHOOK_SECRET=your_webhook_secret_here

# ─── Webhook Server Port ────────────────────────────────
WEBHOOK_PORT=8001
